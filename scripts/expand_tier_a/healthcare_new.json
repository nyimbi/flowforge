  {
    "id": "credential_provider",
    "title": "Credential and privilege a clinical provider",
    "actor": {
      "role": "medical_staff_coordinator"
    },
    "situation": "new physician, NP, or PA must be credentialed before seeing patients: primary source verification of licenses, malpractice history, DEA, board certifications, and hospital privileges",
    "motivation": "ensure only qualified, verified providers render care to patients",
    "outcome": "credentials verified; privileges granted; provider active in scheduling and billing",
    "success_criteria": [
      "all licenses verified through primary sources",
      "malpractice history reviewed (past 5 years)",
      "DEA registration verified",
      "privileges granted per department-specific criteria",
      "provider active in scheduling and billing systems"
