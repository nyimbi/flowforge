        {"trigger": "approved",     "channel": "email",  "audience": "distributor_name"},
        {"trigger": "rejected",     "channel": "email",  "audience": "distribution_manager"},
        {"trigger": "sla_warn",     "channel": "in_app", "audience": "distribution_manager"},
        {"trigger": "sla_breach",   "channel": "slack",  "audience": "distribution_manager"}
      ],
      "sla": {"warn_pct": 75, "breach_seconds": 864000},
