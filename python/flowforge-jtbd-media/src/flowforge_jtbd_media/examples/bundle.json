      "data_capture": [
        {"id": "deal_ref",         "kind": "text",    "label": "Deal reference",           "required": true,  "pii": false},
        {"id": "distributor_name", "kind": "text",    "label": "Distributor name",         "required": true,  "pii": false},
        {"id": "titles",           "kind": "textarea","label": "Titles / catalogue scope", "required": true,  "pii": false},
        {"id": "territory",        "kind": "textarea","label": "Distribution territory",   "required": true,  "pii": false},
        {"id": "window_type",      "kind": "enum",    "label": "Distribution window",      "required": true,  "pii": false},
        {"id": "deal_value",       "kind": "money",   "label": "Minimum guarantee",        "required": true,  "pii": false},
        {"id": "revenue_share_pct","kind": "number",  "label": "Revenue share (%)",        "required": false, "pii": false},
        {"id": "exclusivity",      "kind": "boolean", "label": "Exclusive window",         "required": true,  "pii": false},
        {"id": "term_months",      "kind": "number",  "label": "Deal term (months)",       "required": true,  "pii": false},
        {"id": "signed_agreement", "kind": "file",    "label": "Signed distribution agreement","required": false,"pii": false}
      ],
      "edge_cases": [
        {"id": "exclusivity_conflict","condition": "exclusivity == true and title already licensed in territory","handle": "reject"},
        {"id": "below_floor_price",  "condition": "deal_value < minimum_floor_price for window_type",         "handle": "escalate"},
        {"id": "unvetted_distributor","condition": "distributor not in approved partner register",             "handle": "branch", "branch_to": "distributor_vetting"}
      ],
