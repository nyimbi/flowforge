        {"id": "benchmarking_url", "kind": "url",     "label": "Benchmarking study URL",    "required": true,  "pii": false},
        {"id": "local_file_urls",  "kind": "textarea","label": "Local file document URLs",  "required": false, "pii": false},
        {"id": "cbcr_filed",       "kind": "boolean", "label": "CbCR filed with HQ authority","required": true,"pii": false}
      ],
      "edge_cases": [
