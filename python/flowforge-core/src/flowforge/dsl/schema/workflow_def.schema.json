{
  "$id": "https://flowforge.dev/schemas/workflow_def-1.0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowDef",
  "type": "object",
  "required": ["key", "version", "subject_kind", "initial_state", "states"],
  "additionalProperties": false,
  "properties": {
    "key": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "version": { "type": "string" },
    "subject_kind": { "type": "string" },
    "initial_state": { "type": "string" },
    "metadata": { "type": "object", "additionalProperties": true },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/state" }
    },
    "transitions": {
      "type": "array",
      "items": { "$ref": "#/$defs/transition" }
    },
    "escalations": {
      "type": "array",
      "items": { "$ref": "#/$defs/escalation" }
    }
  },
  "$defs": {
    "state": {
      "type": "object",
      "required": ["name", "kind"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "kind": {
          "enum": [
            "manual_review", "automatic", "parallel_fork", "parallel_join",
            "timer", "signal_wait", "subworkflow",
            "terminal_success", "terminal_fail"
          ]
        },
        "swimlane": { "type": "string" },
        "form_spec_id": { "type": "string" },
        "documents": { "type": "array", "items": { "type": "object" } },
        "sla": { "$ref": "#/$defs/sla" },
        "subworkflow_key": { "type": "string" }
      }
    },
    "sla": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "warn_pct": { "type": "integer", "minimum": 1, "maximum": 99 },
        "breach_seconds": { "type": "integer", "minimum": 60 },
        "pause_aware": { "type": "boolean" }
      }
    },
    "transition": {
      "type": "object",
      "required": ["id", "event", "from_state", "to_state"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "event": { "type": "string" },
        "from_state": { "type": "string" },
        "to_state": { "type": "string" },
        "priority": { "type": "integer", "default": 0 },
        "guards": { "type": "array", "items": { "$ref": "#/$defs/guard" } },
        "gates": { "type": "array", "items": { "$ref": "#/$defs/gate" } },
        "effects": { "type": "array", "items": { "$ref": "#/$defs/effect" } }
      }
    },
    "guard": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "expr" },
        "expr": {}
      }
    },
    "gate": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "permission", "documents_complete", "checklist_complete",
            "approval", "co_signature", "compliance",
            "custom_webhook", "expr"
          ]
        },
        "permission": { "type": "string" },
        "policy": { "type": "string" },
        "tier": { "type": "integer" }
      }
    },
    "effect": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "create_entity", "update_entity", "set", "notify", "audit",
            "emit_signal", "start_subworkflow", "compensate", "http_call"
          ]
        },
        "entity": { "type": "string" },
        "target": { "type": "string" },
        "expr": {},
        "values": { "type": "object", "additionalProperties": true },
        "template": { "type": "string" },
        "signal": { "type": "string" },
        "subworkflow_key": { "type": "string" },
        "compensation_kind": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "escalation": {
      "type": "object",
      "required": ["trigger"],
      "additionalProperties": false,
      "properties": {
        "trigger": {
          "type": "object",
          "required": ["kind"],
          "additionalProperties": false,
          "properties": {
            "kind": { "enum": ["sla_breach", "manual"] },
            "state": { "type": "string" }
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind"],
            "additionalProperties": true,
            "properties": {
              "kind": { "type": "string" },
              "role": { "type": "string" },
              "template": { "type": "string" }
            }
          }
        },
        "cooldown_seconds": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
