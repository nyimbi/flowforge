// Runtime client for {{ project.name }} generated workflow pages.
// Generated by flowforge JTBD generator.

export interface FireWorkflowEventInput {
	readonly workflowPath: string;
	readonly event: string;
	readonly payload?: Record<string, unknown>;
	readonly instanceId: string;
	readonly tenantId: string;
	readonly idempotencyKey?: string;
}

export interface FireWorkflowEventResponse {
	readonly state: string;
	readonly matched?: boolean;
	readonly id?: string;
	readonly _idempotent_replay?: boolean;
}

const API_BASE_URL = (process.env.NEXT_PUBLIC_FLOWFORGE_API_BASE_URL ?? "").replace(/\/$/, "");

function createIdempotencyKey(input: FireWorkflowEventInput): string {
	if (input.idempotencyKey) return input.idempotencyKey;
	const random =
		typeof crypto !== "undefined" && "randomUUID" in crypto
			? crypto.randomUUID()
			: `${Date.now().toString(36)}-${Math.random().toString(36).slice(2)}`;
	return `${input.workflowPath}:${input.instanceId}:${input.event}:${random}`;
}

export async function fireWorkflowEvent(
	input: FireWorkflowEventInput,
): Promise<FireWorkflowEventResponse> {
	const response = await fetch(
		`${API_BASE_URL}/${encodeURIComponent(input.workflowPath)}/events`,
		{
			method: "POST",
			headers: {
				"Content-Type": "application/json",
				"Idempotency-Key": createIdempotencyKey(input),
				"X-Tenant-Id": input.tenantId,
			},
			body: JSON.stringify({
				event: input.event,
				instance_id: input.instanceId,
				payload: input.payload ?? {},
			}),
		},
	);
	const body = await response.json().catch(() => ({}));
	if (!response.ok) {
		const detail = typeof body.detail === "string" ? body.detail : response.statusText;
		throw new Error(`Workflow event failed (${response.status}): ${detail}`);
	}
	if (typeof body.state !== "string" || body.state.length === 0) {
		throw new Error("Workflow event response did not include a state");
	}
	return body as FireWorkflowEventResponse;
}
