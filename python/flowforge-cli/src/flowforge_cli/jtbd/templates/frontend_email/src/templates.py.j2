"""Outbound email templates for {{ project.name }}.

Generated by flowforge JTBD generator — do not edit by hand. One
template per audit topic the bundle aggregates; hosts substitute
``{tenant_id}`` / ``{instance_id}`` / ``{actor}`` / ``{reply_token}``
placeholders at send time.

The reply grammar suffix ``[<jtbd>:<event>:<instance_id>]`` is appended
by the host's notification adapter (the audit topic alone does not
imply which event the recipient should fire on reply — that's a
business decision the host owns).
"""

from __future__ import annotations

from dataclasses import dataclass


@dataclass(frozen=True)
class EmailTemplate:
	"""One outbound notification template, keyed by audit topic."""

	topic: str
	subject_template: str
	body_template: str


# Closed catalog of email templates, sorted by topic so the file is
# deterministic across regens. Hosts call ``template_for(topic)`` to
# look one up before rendering placeholders.
EMAIL_TEMPLATES: dict[str, EmailTemplate] = {
{% for topic in audit_topics %}
	"{{ topic }}": EmailTemplate(
		topic="{{ topic }}",
		subject_template="[{{ topic }}] instance {instance_id} {reply_token}",
		body_template=(
			"Hello,\n\n"
			"The {{ topic }} event fired on instance {instance_id} "
			"(tenant {tenant_id}) by {actor}.\n\n"
			"Reply with the appropriate event token in the subject suffix "
			"to advance the workflow.\n\n"
			"-- {{ project.name }}\n"
		),
	),
{% endfor %}
}


def template_for(topic: str) -> EmailTemplate | None:
	"""Return the template registered for *topic* (or ``None``)."""

	assert isinstance(topic, str), "topic must be a string"
	return EMAIL_TEMPLATES.get(topic)
