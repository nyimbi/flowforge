"""Cross-bundle notifications router config for {{ project.name }}.

Generated by flowforge JTBD generator. Each entry maps a workflow
trigger to a (channel, audience) pair the host's notify adapter uses
to render + dispatch.
"""

from __future__ import annotations

from typing import TypedDict


class NotificationRule(TypedDict):
	trigger: str
	channel: str
	audience: str


NOTIFICATIONS: tuple[NotificationRule, ...] = (
{% for n in bundle.all_notifications %}
	NotificationRule(trigger="{{ n.trigger }}", channel="{{ n.channel }}", audience="{{ n.audience }}"),
{% endfor %}
)
