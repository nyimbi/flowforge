"""Typer CLI entry point for {{ project.name }}.

Generated by flowforge JTBD generator — do not edit by hand. Each JTBD
becomes a Typer subapp; each transition event becomes a command under
that subapp. The command tree mirrors the bundle's ``openapi.yaml``
(W1, item 8) one-to-one.

Run ``{{ project.package | replace('_', '-') }}-cli --help`` to enumerate.
"""

from __future__ import annotations

import json
from typing import Any, Optional

import typer

from . import client


app = typer.Typer(
	help="Typer CLI client for {{ project.name }} — fires workflow events into the bundle's FastAPI backend.",
	no_args_is_help=True,
)

{% for jt in jtbds %}
{{ jt.id }}_app = typer.Typer(
	help="{{ jt.title }}",
	no_args_is_help=True,
)
app.add_typer({{ jt.id }}_app, name="{{ jt.url_segment }}")
{% endfor %}

{% for cmd in commands %}

@{{ cmd.jtbd_id }}_app.command("{{ cmd.command_name }}")
def {{ cmd.func_name }}(
{% for field in cmd.fields %}
{% if field.required %}
	{{ field.id }}: {{ field.option_type }} = typer.Option(..., help="{{ field.label }} (required)"),
{% else %}
	{{ field.id }}: Optional[{{ field.option_type }}] = typer.Option(None, help="{{ field.label }}"),
{% endif %}
{% endfor %}
	base_url: str = typer.Option("http://localhost:8000", "--base-url", help="FastAPI backend base URL."),
) -> None:
	"""Fire ``{{ cmd.event }}`` against ``/{{ cmd.url_segment }}/events`` for {{ cmd.jtbd_title }}."""

	payload: dict[str, Any] = {}
{% for field in cmd.fields %}
{% if field.required %}
	payload["{{ field.id }}"] = {{ field.id }}
{% else %}
	if {{ field.id }} is not None:
		payload["{{ field.id }}"] = {{ field.id }}
{% endif %}
{% endfor %}
	result = client.fire_sync(base_url, "{{ cmd.url_segment }}", "{{ cmd.event }}", payload)
	typer.echo(json.dumps(result, indent=2, sort_keys=True))

{% endfor %}

if __name__ == "__main__":
	app()
