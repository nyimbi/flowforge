/*
 * Design tokens for {{ project.name }}.
 * Generated by flowforge JTBD generator (v0.3.0 W3 / item 18).
 * Source of truth for every visual token consumed by the customer-facing
 * frontend and the admin console. Do not edit by hand — re-run
 * ``flowforge jtbd-generate`` after changing ``project.design`` in the
 * bundle.
 */

:root {
	--color-primary: {{ design.primary }};
	--color-accent: {{ design.accent }};
	--font-family: {{ design.font_family }};
	--density: {{ design.density }};
	--density-padding: {% if design.density == "compact" %}0.5rem{% else %}1rem{% endif %};
	--radius-scale: {{ "%g"|format(design.radius_scale) }};
	--radius-sm: {{ "%g"|format(design.radius_scale * 4) }}px;
	--radius-md: {{ "%g"|format(design.radius_scale * 8) }}px;
	--radius-lg: {{ "%g"|format(design.radius_scale * 16) }}px;
}

[data-theme="dark"] {
	--color-primary: {{ design.primary }};
	--color-accent: {{ design.accent }};
}
