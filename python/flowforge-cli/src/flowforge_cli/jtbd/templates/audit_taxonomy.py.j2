"""Cross-bundle audit-event taxonomy for {{ project.name }}.

Generated by flowforge JTBD generator. The audit-pg adapter consumes
``AUDIT_TOPICS`` for chain-validation drift checks.
"""

from __future__ import annotations

AUDIT_TOPICS: tuple[str, ...] = (
{% for topic in bundle.all_audit_topics %}
	"{{ topic }}",
{% endfor %}
)


def is_known(topic: str) -> bool:
	"""``True`` if *topic* was declared by some JTBD in this bundle."""

	return topic in AUDIT_TOPICS
