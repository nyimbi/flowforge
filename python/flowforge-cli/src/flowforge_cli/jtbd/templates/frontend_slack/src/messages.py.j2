"""Block Kit interactive-message templates for {{ project.name }}.

Generated by flowforge JTBD generator — do not edit by hand. One
template per audit topic the bundle aggregates; hosts substitute
``{tenant_id}`` / ``{instance_id}`` / ``{actor}`` placeholders at
publish time.
"""

from __future__ import annotations

from typing import Any


# Closed catalog of Block Kit payloads, keyed by audit topic. Hosts
# fetch a template, substitute placeholders, and POST to a Slack
# webhook. Sorted by topic so the file is deterministic across regens.
INTERACTIVE_MESSAGES: dict[str, dict[str, Any]] = {
{% for topic in audit_topics %}
	"{{ topic }}": {
		"blocks": [
			{
				"type": "section",
				"text": {
					"type": "mrkdwn",
					"text": "*{{ topic }}* — instance `{instance_id}` (tenant `{tenant_id}`)",
				},
			},
			{
				"type": "context",
				"elements": [
					{"type": "mrkdwn", "text": "actor `{actor}`"},
				],
			},
			{
				"type": "actions",
				"block_id": "{{ topic }}",
				"elements": [
					{
						"type": "button",
						"action_id": "{{ topic }}.acknowledge",
						"text": {"type": "plain_text", "text": "Acknowledge"},
						"value": "{instance_id}",
					},
				],
			},
		],
	},
{% endfor %}
}


def template_for(topic: str) -> dict[str, Any] | None:
	"""Return the Block Kit payload registered for *topic* (or ``None``)."""

	assert isinstance(topic, str), "topic must be a string"
	return INTERACTIVE_MESSAGES.get(topic)
