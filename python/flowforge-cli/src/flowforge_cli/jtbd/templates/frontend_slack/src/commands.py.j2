"""Slash-command catalog for {{ project.name }}.

Generated by flowforge JTBD generator — do not edit by hand. The
catalog is closed at generation time; the W3 conformance gate asserts
each entry mirrors a JTBD declared in the bundle.
"""

from __future__ import annotations

from dataclasses import dataclass


@dataclass(frozen=True)
class FieldSpec:
	"""One ``data_capture`` field exposed as a key=value Slack arg."""

	id: str
	label: str
	required: bool


@dataclass(frozen=True)
class CommandSpec:
	"""One slash-command entry: ``/<slash> <event> key=value ...``."""

	jtbd_id: str
	jtbd_title: str
	url_segment: str
	slash: str
	event: str
	fields: tuple[FieldSpec, ...]
	permissions: tuple[str, ...]


SLASH_COMMANDS: tuple[CommandSpec, ...] = (
{% for cmd in commands %}
{% for event in cmd.events %}
	CommandSpec(
		jtbd_id="{{ cmd.jtbd_id }}",
		jtbd_title="{{ cmd.jtbd_title }}",
		url_segment="{{ cmd.url_segment }}",
		slash="{{ cmd.slash }}",
		event="{{ event }}",
		fields=(
{% for field in cmd.fields %}
			FieldSpec(id="{{ field.id }}", label="{{ field.label }}", required={{ field.required }}),
{% endfor %}
		),
		permissions=(
{% for perm in cmd.permissions %}
			"{{ perm }}",
{% endfor %}
		),
	),
{% endfor %}
{% endfor %}
)


def lookup(slash: str, event: str) -> CommandSpec | None:
	"""Return the catalog entry matching ``/<slash> <event>`` or ``None``."""

	assert isinstance(slash, str), "slash must be a string"
	assert isinstance(event, str), "event must be a string"
	for spec in SLASH_COMMANDS:
		if spec.slash == slash and spec.event == event:
			return spec
	return None
