[project]
name = "{{ project.package | replace('_', '-') }}-slack"
version = "0.1.0"
description = "Slack adapter shell for {{ project.name }} (generated by flowforge — do not edit by hand)."
requires-python = ">=3.11"
dependencies = [
	"httpx>=0.27",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ module_name }}"]
