"""Workflow adapter for {{ jtbd.title }}.

Wraps :func:`flowforge.engine.fire.fire` for the ``{{ jtbd.id }}`` workflow.
The host service constructs an instance, then calls :func:`fire_event`
with each user/system event.
"""

from __future__ import annotations

import copy
import json
import time
from contextlib import contextmanager
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Iterator

from flowforge import config as _flowforge_config
from flowforge.dsl import WorkflowDef
from flowforge.engine.fire import FireResult, Instance, fire as _fire, new_instance
from flowforge.ports.metrics import FIRE_DURATION_HISTOGRAM
from flowforge.ports.types import Principal
from flowforge_sqlalchemy import SqlAlchemySnapshotStore, WorkflowInstance
from sqlalchemy import select
from sqlalchemy.exc import IntegrityError
from sqlalchemy.ext.asyncio import AsyncSession, async_sessionmaker
{% if _compensate_transitions %}
from flowforge.engine.saga import CompensationWorker
from ..{{ jtbd.module_name }}.compensation_handlers import (
	register_compensations as _register_jtbd_compensations,
)
{% endif %}


WORKFLOW_KEY = "{{ jtbd.id }}"
_DEF_PATH = Path(__file__).resolve().parents[4] / "workflows" / WORKFLOW_KEY / "definition.json"


# v0.3.0 W2 / item 12 — OpenTelemetry by construction. The OTel import
# is lazy so generated apps run without ``opentelemetry-api`` installed;
# in that case ``_otel_span`` returns a no-op context manager whose shape
# matches OTel's ``start_as_current_span`` so call-site code stays clean.
try:  # pragma: no cover - import-time fast path
	from opentelemetry import trace as _otel_trace
	_OTEL_TRACER: Any = _otel_trace.get_tracer("flowforge.{{ jtbd.id }}")
except ImportError:  # pragma: no cover
	_OTEL_TRACER = None


@contextmanager
def _otel_span(name: str, attributes: dict[str, Any]) -> Iterator[Any]:
	"""Open an OTel span when ``opentelemetry`` is installed; else a no-op."""

	if _OTEL_TRACER is None:
		yield None
		return
	with _OTEL_TRACER.start_as_current_span(name, attributes=attributes) as span:
		yield span


def load_definition() -> WorkflowDef:
	"""Read + parse the JSON DSL definition once per import."""

	raw = json.loads(_DEF_PATH.read_text(encoding="utf-8"))
	return WorkflowDef.model_validate(raw)


_DEF: WorkflowDef | None = None
_INSTANCES: dict[tuple[str, str], Instance] = {}
_SESSION_FACTORY: async_sessionmaker[AsyncSession] | None = None
_AUDIT_SINK: Any | None = None


def _definition() -> WorkflowDef:
	global _DEF
	if _DEF is None:
		_DEF = load_definition()
	return _DEF


def configure_runtime_session_factory(
	session_factory: async_sessionmaker[AsyncSession],
	*,
	audit_sink: Any | None = None,
) -> None:
	"""Use a host-provided SQLAlchemy async session factory for runtime state.

	The generated adapter defaults to an in-memory tenant-scoped snapshot
	map for local demos/tests. Calling this at application boot switches
	``fire_event`` to ``SqlAlchemySnapshotStore.fire_and_commit(...)`` so
	workflow instance rows, snapshots, workflow events, audit rows, and
	durable outbox rows share the existing transactional persistence path.
	"""

	assert session_factory is not None, "session_factory is required"
	global _SESSION_FACTORY, _AUDIT_SINK
	_SESSION_FACTORY = session_factory
	_AUDIT_SINK = audit_sink


def reset_runtime_state() -> None:
	"""Clear the generated in-memory runtime store.

	The default store exists so generated examples can drive multi-event
	flows without silently creating a fresh instance on every event.
	Durable SQLAlchemy rows are owned by the host database and are not
	affected by this helper.
	"""

	_INSTANCES.clear()


def _load_instance(wd: WorkflowDef, *, tenant_id: str, instance_id: str | None) -> Instance:
	if not instance_id:
		return new_instance(wd)
	key = (tenant_id, instance_id)
	existing = _INSTANCES.get(key)
	if existing is None:
		return new_instance(wd, instance_id=instance_id)
	return copy.deepcopy(existing)


def _save_instance(instance: Instance, *, tenant_id: str, instance_id: str | None) -> None:
	if not instance_id:
		return
	_INSTANCES[(tenant_id, instance_id)] = copy.deepcopy(instance)


async def fire_event(
	event: str,
	*,
	payload: dict[str, Any] | None = None,
	instance_id: str | None = None,
	principal: Principal,
	tenant_id: str = "default",
) -> FireResult:
	"""Fire one event against a stable generated instance.

	When ``instance_id`` is provided, the generated testing/runtime shim
	keeps the latest snapshot in a tenant-scoped in-memory map so a
	submit/review/approve sequence advances the same instance. When the
	host calls :func:`configure_runtime_session_factory`, this same
	signature uses the SQLAlchemy snapshot store's transactional
	``fire_and_commit`` path instead.
	"""

	wd = _definition()
	if _SESSION_FACTORY is None:
		instance = _load_instance(wd, tenant_id=tenant_id, instance_id=instance_id)
	else:
		instance = await _load_sqlalchemy_instance(
			wd,
			tenant_id=tenant_id,
			instance_id=instance_id,
		)
	span_attrs: dict[str, Any] = {
		"flowforge.tenant_id": tenant_id,
		"flowforge.jtbd_id": WORKFLOW_KEY,
		"flowforge.state": instance.state,
		"flowforge.event": event,
		"flowforge.principal_user_id": principal.user_id,
	}
	started = time.perf_counter()
	with _otel_span("flowforge.fire", span_attrs) as _span:
		if _SESSION_FACTORY is None:
			result = await _fire(
				wd,
				instance,
				event,
				payload=payload or {},
				principal=principal,
				tenant_id=tenant_id,
			)
		else:
			store = SqlAlchemySnapshotStore(
				_SESSION_FACTORY,
				tenant_id=tenant_id,
				audit_sink=_AUDIT_SINK,
			)
			await _ensure_workflow_instance_row(wd, instance, tenant_id=tenant_id)
			result = await store.fire_and_commit(
				wd=wd,
				instance=instance,
				event=event,
				payload=payload or {},
				principal=principal,
				tenant_id=tenant_id,
				jtbd_id=WORKFLOW_KEY,
				jtbd_version=wd.version,
			)
		if _span is not None:
			_span.set_attribute("flowforge.new_state", result.new_state)
	if _SESSION_FACTORY is None:
		_save_instance(instance, tenant_id=tenant_id, instance_id=instance_id)
	duration_seconds = time.perf_counter() - started
	metrics = getattr(_flowforge_config.current(), "metrics", None)
	if metrics is not None:
		labels = {
			"tenant_id": tenant_id,
			"def_key": WORKFLOW_KEY,
			"state": result.new_state,
			"jtbd_id": WORKFLOW_KEY,
			"jtbd_version": "",
		}
		record_histogram = getattr(metrics, "record_histogram", None)
		if record_histogram is not None:
			record_histogram(FIRE_DURATION_HISTOGRAM, duration_seconds, labels)
		else:
			metrics.emit(FIRE_DURATION_HISTOGRAM, duration_seconds, labels)
	return result


async def _load_sqlalchemy_instance(
	wd: WorkflowDef,
	*,
	tenant_id: str,
	instance_id: str | None,
) -> Instance:
	assert _SESSION_FACTORY is not None
	if not instance_id:
		return new_instance(wd)
	store = SqlAlchemySnapshotStore(_SESSION_FACTORY, tenant_id=tenant_id, audit_sink=_AUDIT_SINK)
	existing = await store.get(instance_id)
	if existing is not None:
		return existing
	return new_instance(wd, instance_id=instance_id)


async def _ensure_workflow_instance_row(
	wd: WorkflowDef,
	instance: Instance,
	*,
	tenant_id: str,
) -> None:
	assert _SESSION_FACTORY is not None
	now = datetime.now(timezone.utc)
	async with _SESSION_FACTORY() as session:
		existing = await session.scalar(
			select(WorkflowInstance.id).where(
				WorkflowInstance.tenant_id == tenant_id,
				WorkflowInstance.id == instance.id,
			)
		)
		if existing is not None:
			return
		session.add(
			WorkflowInstance(
				id=instance.id,
				tenant_id=tenant_id,
				def_key=wd.key,
				def_version=wd.version,
				subject_kind=wd.subject_kind,
				state=instance.state,
				terminal=False,
				context=dict(instance.context),
				created_at=now,
				updated_at=now,
			)
		)
		try:
			await session.commit()
		except IntegrityError:
			await session.rollback()
{% if _compensate_transitions %}


def register_compensations(worker: CompensationWorker) -> None:
	"""Register the synthesised {{ jtbd.id }} saga compensations on *worker*.

	Mirrors the ``compensate`` transitions in this workflow's
	``definition.json``. Hosts call this once at boot so
	:meth:`CompensationWorker.replay_pending` can dispatch the per-kind
	handlers in LIFO order whenever an instance enters the compensation
	point.
	"""

	_register_jtbd_compensations(worker)
{% endif %}
