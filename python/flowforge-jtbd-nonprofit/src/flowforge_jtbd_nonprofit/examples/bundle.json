      ],
      "data_capture": [
        {"id": "audit_year",        "kind": "text",    "label": "Audit year",                "required": true,  "pii": false},
        {"id": "scope_areas",       "kind": "textarea","label": "Audit scope areas",         "required": true,  "pii": false},
        {"id": "findings_count",    "kind": "number",  "label": "Total findings count",      "required": true,  "pii": false},
        {"id": "high_risk_findings","kind": "number",  "label": "High-risk findings",        "required": true,  "pii": false},
        {"id": "report_url",        "kind": "url",     "label": "Audit report URL",          "required": true,  "pii": false},
        {"id": "cap_url",           "kind": "url",     "label": "Corrective action plan URL","required": false, "pii": false}
      ],
      "edge_cases": [
        {"id": "material_breach",   "condition": "finding reveals potential grant misuse",                "handle": "escalate"},
        {"id": "funder_notification","condition": "material breach requires mandatory funder notification","handle": "branch", "branch_to": "funder_incident_notification"},
        {"id": "data_breach",       "condition": "audit uncovers personal data breach",                   "handle": "branch", "branch_to": "data_breach_response"}
      ],
      "approvals": [
        {"role": "compliance_officer",  "policy": "1_of_1"},
        {"role": "executive_director",  "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "compliance_officer"},
        {"trigger": "approved",    "channel": "email",  "audience": "executive_director"},
        {"trigger": "sla_warn",    "channel": "slack",  "audience": "compliance_officer"}
      ],
      "sla": {"warn_pct": 75, "breach_seconds": 864000},
      "metrics": ["finding_closure_rate", "repeat_finding_rate", "high_risk_remediation_days"],
      "compliance": ["OMB-2-CFR-200.514", "GDPR-Art5", "IRS-Form-990-PartVI", "Charities-Act-2011"],
      "data_sensitivity": ["restricted"]
    },
    {
      "id": "enroll_beneficiary",
      "title": "Enroll a programme beneficiary",
      "actor": {"role": "program_officer"},
      "situation": "a prospective beneficiary applies to receive services and must be screened for eligibility, consented, and enrolled in the programme",
      "motivation": "enroll eligible individuals quickly to maximise programme reach while maintaining funder-mandated eligibility records",
      "outcome": "beneficiary screened, eligibility confirmed, informed consent obtained, and services commenced",
      "success_criteria": [
        "eligibility determination completed within 5 business days of application",
        "informed consent form signed before first service delivery",
        "beneficiary record created in case management system before commencement"
      ],
      "data_capture": [
        {"id": "applicant_name",    "kind": "text",     "label": "Applicant full name",       "required": true,  "pii": true},
        {"id": "applicant_dob",     "kind": "date",     "label": "Date of birth",             "required": true,  "pii": true},
        {"id": "eligibility_score", "kind": "number",   "label": "Eligibility score (0-100)", "required": true,  "pii": false},
        {"id": "consent_signed",    "kind": "boolean",  "label": "Informed consent signed",   "required": true,  "pii": false},
        {"id": "service_start",     "kind": "date",     "label": "Service commencement date", "required": false, "pii": false},
        {"id": "referral_source",   "kind": "enum",     "label": "Referral source",           "required": true,  "pii": false}
      ],
      "edge_cases": [
        {"id": "ineligible",        "condition": "eligibility_score < programme threshold",               "handle": "reject"},
        {"id": "waitlist",          "condition": "programme capacity is full at time of eligibility confirmation","handle": "branch", "branch_to": "waitlist_management"},
        {"id": "vulnerable_adult",  "condition": "applicant is a vulnerable adult requiring additional safeguarding","handle": "branch", "branch_to": "safeguarding_assessment"}
      ],
      "approvals": [
        {"role": "program_officer", "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "program_officer"},
        {"trigger": "approved",    "channel": "email",  "audience": "program_officer"},
        {"trigger": "rejected",    "channel": "email",  "audience": "program_officer"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "program_officer"}
      ],
      "sla": {"warn_pct": 80, "breach_seconds": 432000},
      "metrics": ["enrollment_cycle_time", "eligibility_approval_rate", "beneficiary_waitlist_count"],
      "compliance": ["GDPR-Art6", "HIPAA-if-applicable", "Safeguarding-Vulnerable-Groups-Act", "OMB-2-CFR-200"],
      "data_sensitivity": ["pii", "restricted"]
    }
  ]
}
