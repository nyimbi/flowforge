      "actor": {"role": "health_information_manager"},
      "situation": "patient, attorney, insurer, or government entity requests medical records; HIM must verify authorization, redact non-authorized information, and release within statutory timeframes",
      "motivation": "fulfill the patient's right of access and legal obligations while protecting PHI and preventing unauthorized disclosure",
      "outcome": "records released to authorized requester, access log updated, fees collected if applicable",
      "success_criteria": [
        "valid authorization verified before any release",
        "records provided within 30 days of request (HIPAA)",
        "urgent requests fulfilled within 3 business days",
        "minimum necessary standard applied to all releases",
        "accounting of disclosures maintained for non-TPO releases"
      ],
      "data_capture": [
        {"id": "patient_mrn",         "kind": "text",     "label": "MRN",                    "required": true,  "pii": true},
        {"id": "requester_name",      "kind": "text",     "label": "Requester name",         "required": true,  "pii": true},
        {"id": "requester_type",      "kind": "enum",     "label": "Requester type",         "required": true,  "pii": false},
        {"id": "authorization_form",  "kind": "file",     "label": "Signed authorization",   "required": true,  "pii": true},
        {"id": "records_requested",   "kind": "textarea", "label": "Records requested",      "required": true,  "pii": false},
