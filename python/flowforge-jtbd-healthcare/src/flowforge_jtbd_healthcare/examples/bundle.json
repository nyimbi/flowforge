{
  "project": {
    "name": "healthcare-example",
    "package": "healthcare_example",
    "domain": "healthcare",
    "tenancy": "multi",
    "languages": ["en"],
    "currencies": ["USD"]
  },
  "shared": {
    "roles": [
      "patient", "admissions_coordinator", "attending_physician",
      "nurse", "case_manager", "utilization_reviewer",
      "medical_coder", "billing_specialist", "prior_auth_specialist",
      "referral_coordinator", "pharmacist", "research_coordinator",
      "risk_manager", "health_information_manager", "patient_advocate"
    ],
    "permissions": [
      "hc.patient.admit", "hc.patient.discharge", "hc.appointment.schedule",
      "hc.auth.request", "hc.claim.submit", "hc.referral.create",
      "hc.prescription.process", "hc.trial.enroll", "hc.incident.report",
      "hc.record.request"
    ]
  },
  "jtbds": [
    {
      "id": "admit_patient",
      "title": "Admit a patient for inpatient care",
      "actor": {"role": "admissions_coordinator"},
      "situation": "patient presents for scheduled or emergency inpatient admission; coordinator must verify benefits, obtain authorization, assign bed, and complete consents",
      "motivation": "ensure patient receives timely care with coverage verified to prevent revenue denials",
      "outcome": "patient admitted with signed consents, authorization number obtained, bed assigned",
      "success_criteria": [
        "insurance verified and authorization obtained before or within 24 hours of emergency admission",
        "signed consent forms collected before first procedure",
        "bed assigned within 2 hours of admission order",
        "HIPAA notice of privacy practices delivered and acknowledged"
      ],
      "data_capture": [
        {"id": "patient_mrn",         "kind": "text",     "label": "Medical record number",  "required": true,  "pii": true},
        {"id": "patient_name",        "kind": "text",     "label": "Patient full name",       "required": true,  "pii": true},
        {"id": "dob",                 "kind": "date",     "label": "Date of birth",           "required": true,  "pii": true},
        {"id": "ssn_ref",             "kind": "text",     "label": "SSN reference (masked)",  "required": false, "pii": true},
        {"id": "insurance_id",        "kind": "text",     "label": "Insurance member ID",     "required": true,  "pii": false},
        {"id": "admission_type",      "kind": "enum",     "label": "Admission type",          "required": true,  "pii": false},
        {"id": "admitting_dx",        "kind": "text",     "label": "Admitting diagnosis",     "required": true,  "pii": false},
        {"id": "auth_number",         "kind": "text",     "label": "Authorization number",    "required": false, "pii": false},
        {"id": "consent_forms",       "kind": "signature","label": "Signed consents",         "required": true,  "pii": true}
      ],
      "edge_cases": [
        {"id": "no_coverage",         "condition": "insurance_verification = no_coverage",    "handle": "branch", "branch_to": "self_pay_counseling"},
        {"id": "auth_denied",         "condition": "prior_auth_result = denied",              "handle": "branch", "branch_to": "appeal_authorization"},
        {"id": "capacity_full",       "condition": "bed_availability = 0",                   "handle": "escalate"}
      ],
      "approvals": [
        {"role": "attending_physician", "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "patient"},
        {"trigger": "approved",    "channel": "in_app", "audience": "nurse"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "admissions_coordinator"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "case_manager"}
      ],
      "sla": {"warn_pct": 75, "breach_seconds": 86400},
      "metrics": ["admission_to_bed_time", "auth_denial_rate", "registration_accuracy_pct"],
      "compliance": ["HIPAA", "EMTALA", "CMS_CoP", "Joint_Commission", "GDPR"],
      "data_sensitivity": ["phi", "pii", "financial"]
    },
    {
      "id": "schedule_appointment",
      "title": "Schedule a patient appointment",
      "actor": {"role": "admissions_coordinator"},
      "situation": "patient or referring provider requests an appointment; coordinator must check availability, verify insurance eligibility, and confirm scheduling",
      "motivation": "minimize patient wait time and maximize provider schedule utilization while ensuring coverage is active",
      "outcome": "appointment confirmed, eligibility verified, reminders sent to patient",
      "success_criteria": [
        "appointment offered within 7 days for routine, 24 hours for urgent",
        "insurance eligibility verified at time of scheduling",
        "appointment reminder sent 48 hours and 2 hours before visit",
        "no-show rate < 10%"
      ],
      "data_capture": [
        {"id": "patient_mrn",         "kind": "text",  "label": "MRN (or new patient flag)", "required": true,  "pii": true},
        {"id": "appointment_type",    "kind": "enum",  "label": "Appointment type",          "required": true,  "pii": false},
        {"id": "requested_provider",  "kind": "text",  "label": "Requested provider",        "required": false, "pii": false},
        {"id": "preferred_dates",     "kind": "text",  "label": "Preferred dates",           "required": false, "pii": false},
        {"id": "chief_complaint",     "kind": "textarea","label": "Chief complaint",         "required": true,  "pii": false},
        {"id": "eligibility_result",  "kind": "text",  "label": "Eligibility check result",  "required": true,  "pii": false},
        {"id": "appointment_datetime","kind": "datetime","label": "Scheduled date/time",     "required": true,  "pii": false}
      ],
      "edge_cases": [
        {"id": "no_eligibility",      "condition": "eligibility_result = inactive",          "handle": "branch", "branch_to": "financial_counseling"},
        {"id": "urgent_triage",       "condition": "chief_complaint_urgency = urgent",       "handle": "branch", "branch_to": "same_day_scheduling"},
        {"id": "no_show_pattern",     "condition": "patient_no_show_count > 2",              "handle": "escalate"}
      ],
      "notifications": [
        {"trigger": "state_enter",  "channel": "email", "audience": "patient"},
        {"trigger": "approved",     "channel": "sms",   "audience": "patient"},
        {"trigger": "sla_warn",     "channel": "in_app","audience": "admissions_coordinator"}
      ],
      "sla": {"warn_pct": 80, "breach_seconds": 604800},
      "metrics": ["days_to_appointment", "no_show_rate", "eligibility_denial_rate", "schedule_utilization_pct"],
      "compliance": ["HIPAA", "ADA_accessibility", "CMS_access_standards"],
      "data_sensitivity": ["phi", "pii"]
    },
    {
      "id": "process_prior_authorization",
      "title": "Process prior authorization request",
      "actor": {"role": "prior_auth_specialist"},
      "situation": "payer requires authorization before procedure, medication, or specialist visit; specialist must submit clinical criteria and obtain approval before service rendered",
      "motivation": "prevent claim denials by obtaining payer approval in advance, while minimizing treatment delays for patients",
      "outcome": "authorization approved or denied, appeal initiated if denied, authorization number documented in chart",
      "success_criteria": [
        "initial authorization request submitted within 24 hours of order",
        "urgent authorization escalated to payer within 4 hours",
        "appeal filed within 30 days of denial",
        "authorization number entered in scheduling system before procedure"
      ],
      "data_capture": [
        {"id": "patient_mrn",         "kind": "text",    "label": "MRN",                      "required": true,  "pii": true},
        {"id": "procedure_code",      "kind": "text",    "label": "CPT/HCPCS code",            "required": true,  "pii": false},
        {"id": "diagnosis_code",      "kind": "text",    "label": "ICD-10 diagnosis code",    "required": true,  "pii": false},
        {"id": "payer_id",            "kind": "text",    "label": "Payer ID",                  "required": true,  "pii": false},
        {"id": "clinical_notes",      "kind": "textarea","label": "Clinical justification",   "required": true,  "pii": false},
        {"id": "urgency_flag",        "kind": "boolean", "label": "Urgent request",            "required": true,  "pii": false},
        {"id": "auth_number",         "kind": "text",    "label": "Authorization number",      "required": false, "pii": false},
        {"id": "auth_valid_through",  "kind": "date",    "label": "Authorization valid through","required": false,"pii": false}
      ],
      "edge_cases": [
        {"id": "urgent_escalation",   "condition": "urgency_flag = true",                    "handle": "escalate"},
        {"id": "auth_denied",         "condition": "payer_decision = denied",               "handle": "branch", "branch_to": "peer_to_peer_review"},
        {"id": "auth_expired",        "condition": "service_date > auth_valid_through",     "handle": "branch", "branch_to": "reauthorization"}
      ],
      "approvals": [
        {"role": "attending_physician", "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "in_app", "audience": "prior_auth_specialist"},
        {"trigger": "approved",    "channel": "email",  "audience": "patient"},
        {"trigger": "rejected",    "channel": "in_app", "audience": "prior_auth_specialist"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "prior_auth_specialist"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "case_manager"}
      ],
      "sla": {"warn_pct": 70, "breach_seconds": 86400},
      "metrics": ["auth_approval_rate", "time_to_auth_decision", "denial_overturn_rate", "treatment_delay_days"],
      "compliance": ["HIPAA", "ACA_parity_rules", "CMS_prior_auth_final_rule_2024"],
      "data_sensitivity": ["phi", "pii"]
    },
    {
      "id": "submit_insurance_claim",
      "title": "Submit and follow up on insurance claim",
      "actor": {"role": "billing_specialist"},
      "situation": "services rendered; billing specialist must code the encounter, validate claim data, submit electronically to payer, and follow up on unpaid or rejected claims",
      "motivation": "maximize clean claim rate and collect accounts receivable within payer timely filing limits",
      "outcome": "claim paid, posted to patient account, and ERA reconciled; denials worked or appealed",
      "success_criteria": [
        "claim submitted within 3 business days of service date",
        "clean claim rate > 95%",
        "denial worked within 10 business days of receipt",
        "timely filing limit met for all payers"
      ],
      "data_capture": [
        {"id": "patient_mrn",        "kind": "text",  "label": "MRN",                      "required": true,  "pii": true},
        {"id": "service_date",       "kind": "date",  "label": "Date of service",          "required": true,  "pii": false},
        {"id": "procedure_codes",    "kind": "text",  "label": "CPT codes",                "required": true,  "pii": false},
        {"id": "diagnosis_codes",    "kind": "text",  "label": "ICD-10 codes",             "required": true,  "pii": false},
        {"id": "billed_amount",      "kind": "money", "label": "Billed charges",           "required": true,  "pii": false},
        {"id": "payer_id",           "kind": "text",  "label": "Payer ID",                 "required": true,  "pii": false},
        {"id": "claim_number",       "kind": "text",  "label": "Claim number",             "required": false, "pii": false},
        {"id": "remittance_amount",  "kind": "money", "label": "Remittance paid amount",   "required": false, "pii": false}
      ],
      "edge_cases": [
        {"id": "timely_filing_risk",  "condition": "days_since_service > payer_filing_limit - 10", "handle": "escalate"},
        {"id": "coding_error",        "condition": "claim_edit_count > 0",                         "handle": "branch", "branch_to": "coding_review"},
        {"id": "coordination_of_benefits", "condition": "patient_has_multiple_payers = true",     "handle": "branch", "branch_to": "cob_workflow"}
      ],
      "approvals": [
        {"role": "medical_coder", "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "in_app", "audience": "billing_specialist"},
        {"trigger": "rejected",    "channel": "in_app", "audience": "billing_specialist"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "billing_specialist"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "billing_specialist"}
      ],
      "sla": {"warn_pct": 80, "breach_seconds": 259200},
      "metrics": ["clean_claim_rate", "days_in_AR", "denial_rate", "first_pass_resolution_rate"],
      "compliance": ["HIPAA_837", "CMS_timely_filing", "OIG_false_claims_act", "GDPR"],
      "data_sensitivity": ["phi", "pii", "financial"]
    },
    {
      "id": "manage_referral",
      "title": "Manage specialist referral",
      "actor": {"role": "referral_coordinator"},
      "situation": "attending physician orders a specialist referral; coordinator must obtain authorization, identify in-network specialist, transmit clinical summary, and track appointment completion",
      "motivation": "ensure continuity of care and avoid out-of-network liability while meeting the physician's clinical timeline",
      "outcome": "referral authorized, specialist appointment scheduled, consult note received back in chart",
      "success_criteria": [
        "referral authorization requested within 24 hours of order",
        "specialist appointment scheduled within 5 business days of authorization",
        "consult note received and scanned within 3 business days of specialist visit",
        "referring physician notified of consult findings"
      ],
      "data_capture": [
        {"id": "patient_mrn",         "kind": "text",    "label": "MRN",                    "required": true,  "pii": true},
        {"id": "referring_physician", "kind": "text",    "label": "Referring physician",    "required": true,  "pii": false},
        {"id": "specialty_requested", "kind": "enum",    "label": "Specialty",              "required": true,  "pii": false},
        {"id": "referral_reason",     "kind": "textarea","label": "Referral reason",        "required": true,  "pii": false},
        {"id": "urgency",             "kind": "enum",    "label": "Urgency level",          "required": true,  "pii": false},
        {"id": "auth_number",         "kind": "text",    "label": "Authorization number",   "required": false, "pii": false},
        {"id": "specialist_name",     "kind": "text",    "label": "Specialist assigned",    "required": false, "pii": false},
        {"id": "consult_note",        "kind": "file",    "label": "Consult note",           "required": false, "pii": false}
      ],
      "edge_cases": [
        {"id": "out_of_network",      "condition": "specialist_network_status = OON",       "handle": "escalate"},
        {"id": "auth_denied",         "condition": "auth_result = denied",                  "handle": "branch", "branch_to": "referral_appeal"},
        {"id": "no_response",         "condition": "specialist_appointment_not_scheduled_in_5_days", "handle": "escalate"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "patient"},
        {"trigger": "approved",    "channel": "email",  "audience": "patient"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "referral_coordinator"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "case_manager"}
      ],
      "sla": {"warn_pct": 75, "breach_seconds": 432000},
      "metrics": ["referral_completion_rate", "time_to_specialist", "consult_note_return_rate", "oon_referral_rate"],
      "compliance": ["HIPAA", "ACA_network_adequacy", "CMS_CoP"],
      "data_sensitivity": ["phi", "pii"]
    },
    {
      "id": "handle_discharge",
      "title": "Coordinate patient discharge",
      "actor": {"role": "case_manager"},
      "situation": "attending physician writes discharge order; case manager must coordinate post-acute placement, arrange follow-up, reconcile medications, and obtain patient education acknowledgement",
      "motivation": "prevent avoidable readmissions and ensure patient has safe, appropriate discharge destination with required follow-up in place",
      "outcome": "patient discharged with care transition plan, medication reconciliation complete, follow-up scheduled",
      "success_criteria": [
        "discharge planning initiated within 24 hours of admission",
        "medication reconciliation completed before discharge",
        "follow-up appointment scheduled within 7 days for high-risk patients",
        "30-day readmission rate < 10%"
      ],
      "data_capture": [
        {"id": "patient_mrn",           "kind": "text",     "label": "MRN",                       "required": true,  "pii": true},
        {"id": "discharge_destination", "kind": "enum",     "label": "Discharge destination",     "required": true,  "pii": false},
        {"id": "discharge_diagnosis",   "kind": "text",     "label": "Discharge diagnosis (ICD)", "required": true,  "pii": false},
        {"id": "discharge_datetime",    "kind": "datetime", "label": "Discharge date/time",       "required": true,  "pii": false},
        {"id": "medication_list",       "kind": "textarea", "label": "Reconciled medication list","required": true,  "pii": false},
        {"id": "followup_appointment",  "kind": "date",     "label": "Follow-up appointment date","required": false, "pii": false},
        {"id": "patient_education_ack", "kind": "signature","label": "Patient education acknowledgement","required": true,"pii": true}
      ],
      "edge_cases": [
        {"id": "against_medical_advice","condition": "patient_leaving_ama = true",            "handle": "branch", "branch_to": "ama_documentation"},
        {"id": "no_safe_discharge",     "condition": "discharge_destination = none_available","handle": "escalate"},
        {"id": "insurance_denied_snf",  "condition": "snf_auth_denied = true",               "handle": "escalate"}
      ],
      "approvals": [
        {"role": "attending_physician", "policy": "1_of_1"},
        {"role": "utilization_reviewer","policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "patient"},
        {"trigger": "approved",    "channel": "email",  "audience": "patient"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "case_manager"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "case_manager"}
      ],
      "sla": {"warn_pct": 80, "breach_seconds": 86400},
      "metrics": ["30day_readmission_rate", "discharge_delay_hours", "med_rec_completion_rate", "followup_scheduling_rate"],
      "compliance": ["HIPAA", "CMS_discharge_planning_rule", "Joint_Commission", "HCAHPS"],
      "data_sensitivity": ["phi", "pii"]
    },
    {
      "id": "process_prescription",
      "title": "Process and verify prescription",
      "actor": {"role": "pharmacist"},
      "situation": "prescriber submits prescription (electronic or paper); pharmacist must verify patient identity, check interactions, confirm coverage, and dispense or counsel on alternatives",
      "motivation": "ensure patient receives the correct medication at appropriate dose with no harmful interactions and with insurance coverage confirmed",
      "outcome": "prescription dispensed or therapeutic alternative offered, patient counseled, PDMP checked",
      "success_criteria": [
        "PDMP checked for all Schedule II-IV medications",
        "drug interaction screening completed before dispensing",
        "patient counseled on new medications",
        "controlled substance verified against DEA number"
      ],
      "data_capture": [
        {"id": "patient_mrn",        "kind": "text",    "label": "MRN",                     "required": true,  "pii": true},
        {"id": "drug_name",          "kind": "text",    "label": "Drug name",               "required": true,  "pii": false},
        {"id": "ndc_code",           "kind": "text",    "label": "NDC code",                "required": true,  "pii": false},
        {"id": "dose",               "kind": "text",    "label": "Dose and frequency",      "required": true,  "pii": false},
        {"id": "days_supply",        "kind": "number",  "label": "Days supply",             "required": true,  "pii": false},
        {"id": "prescriber_dea",     "kind": "text",    "label": "Prescriber DEA number",   "required": false, "pii": false},
        {"id": "pdmp_check_result",  "kind": "text",    "label": "PDMP check result",       "required": false, "pii": false},
        {"id": "copay_amount",       "kind": "money",   "label": "Patient copay",           "required": false, "pii": false}
      ],
      "edge_cases": [
        {"id": "drug_interaction",   "condition": "interaction_severity = major",            "handle": "escalate"},
        {"id": "pdmp_alert",         "condition": "pdmp_result = multiple_prescribers",      "handle": "escalate"},
        {"id": "coverage_denied",    "condition": "insurance_coverage = not_covered",        "handle": "branch", "branch_to": "prior_auth_or_alternative"},
        {"id": "dea_invalid",        "condition": "dea_validation = invalid",               "handle": "reject"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "sms",   "audience": "patient"},
        {"trigger": "approved",    "channel": "sms",   "audience": "patient"},
        {"trigger": "sla_warn",    "channel": "in_app","audience": "pharmacist"}
      ],
      "sla": {"warn_pct": 80, "breach_seconds": 3600},
      "metrics": ["dispensing_error_rate", "pdmp_compliance_rate", "coverage_denial_rate", "time_to_dispense"],
      "compliance": ["HIPAA", "DEA_21CFR_1306", "PDMP_state_statutes", "USP_797_800"],
      "data_sensitivity": ["phi", "pii", "controlled_substance"]
    },
    {
      "id": "enroll_clinical_trial",
      "title": "Enroll patient in clinical trial",
      "actor": {"role": "research_coordinator"},
      "situation": "patient meets eligibility criteria for an IRB-approved trial; coordinator must obtain informed consent, verify eligibility, randomize, and register in CTMS",
      "motivation": "advance research while protecting patient rights, ensuring protocol compliance, and meeting enrollment targets",
      "outcome": "patient enrolled, consent documented, baseline data collected, CTMS record created",
      "success_criteria": [
        "informed consent obtained before any protocol procedures",
        "eligibility confirmation documented in source records",
        "subject randomization completed per protocol",
        "FDA Form 1572 on file for IND studies",
        "enrollment registered on ClinicalTrials.gov within 21 days"
      ],
      "data_capture": [
        {"id": "patient_mrn",          "kind": "text",     "label": "MRN",                      "required": true,  "pii": true},
        {"id": "protocol_id",          "kind": "text",     "label": "Protocol ID",              "required": true,  "pii": false},
        {"id": "irb_approval_number",  "kind": "text",     "label": "IRB approval number",      "required": true,  "pii": false},
        {"id": "informed_consent_doc", "kind": "signature","label": "Signed informed consent",  "required": true,  "pii": true},
        {"id": "eligibility_checklist","kind": "file",     "label": "Eligibility checklist",    "required": true,  "pii": false},
        {"id": "randomization_code",   "kind": "text",     "label": "Randomization code",       "required": false, "pii": false},
        {"id": "baseline_visit_date",  "kind": "date",     "label": "Baseline visit date",      "required": true,  "pii": false}
      ],
      "edge_cases": [
        {"id": "screen_failure",       "condition": "eligibility_met = false",                  "handle": "reject"},
        {"id": "consent_withdrawn",    "condition": "patient_withdraws_consent = true",         "handle": "branch", "branch_to": "withdrawal_procedure"},
        {"id": "sae_during_screening", "condition": "serious_adverse_event_during_screening",   "handle": "escalate"}
      ],
      "approvals": [
        {"role": "attending_physician",   "policy": "1_of_1"},
        {"role": "research_coordinator",  "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "patient"},
        {"trigger": "approved",    "channel": "email",  "audience": "research_coordinator"},
        {"trigger": "rejected",    "channel": "email",  "audience": "patient"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "research_coordinator"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "research_coordinator"}
      ],
      "sla": {"warn_pct": 80, "breach_seconds": 1814400},
      "metrics": ["enrollment_rate", "screen_failure_rate", "consent_to_enrollment_days", "protocol_deviation_rate"],
      "compliance": ["FDA_21CFR_50", "FDA_21CFR_56", "ICH_GCP_E6", "HIPAA", "GDPR_clinical_trials"],
      "data_sensitivity": ["phi", "pii", "research_data", "sensitive"]
    },
    {
      "id": "handle_incident_report",
      "title": "Handle patient safety incident report",
      "actor": {"role": "risk_manager"},
      "situation": "staff member reports an adverse event, near-miss, or sentinel event; risk manager must investigate, classify, conduct RCA if required, and implement corrective actions",
      "motivation": "prevent recurrence of patient harm, meet Joint Commission sentinel event reporting obligations, and protect the organization from liability",
      "outcome": "incident classified, root cause analysis completed, corrective action plan implemented and monitored",
      "success_criteria": [
        "incident acknowledged within 1 hour of report",
        "preliminary assessment completed within 24 hours",
        "root cause analysis completed within 45 days for sentinel events",
        "corrective action plan implemented and verified within 90 days",
        "Joint Commission notified within 5 business days for sentinel events"
      ],
      "data_capture": [
        {"id": "incident_date",       "kind": "datetime","label": "Incident date/time",     "required": true,  "pii": false},
        {"id": "incident_type",       "kind": "enum",    "label": "Incident type",          "required": true,  "pii": false},
