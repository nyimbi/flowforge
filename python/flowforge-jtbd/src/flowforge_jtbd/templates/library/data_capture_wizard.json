{
  "id": "data_capture_wizard",
  "name": "Data Capture Wizard",
  "description": "Multi-step data collection wizard where each step validates before proceeding to the next.",
  "tags": [
    "data-capture",
    "wizard",
    "onboarding",
    "intake"
  ],
  "parameters": [
    {
      "name": "workflow_key",
      "type": "string",
      "required": true
    },
    {
      "name": "subject_kind",
      "type": "string",
      "required": true
    },
    {
      "name": "step_count",
      "type": "integer",
      "required": false,
      "default": 3
    }
  ],
  "workflow_template": {
    "key": "{{workflow_key}}",
    "version": "1.0.0",
    "subject_kind": "{{subject_kind}}",
    "initial_state": "step_1",
    "states": [
      {
        "name": "step_1",
        "kind": "manual_review"
      },
      {
        "name": "step_2",
        "kind": "manual_review"
      },
      {
        "name": "step_3",
        "kind": "manual_review"
      },
      {
        "name": "submitted",
        "kind": "terminal_success"
      },
      {
        "name": "abandoned",
        "kind": "terminal_fail"
      }
    ],
    "transitions": [
      {
        "id": "next_1",
        "event": "next",
        "from_state": "step_1",
        "to_state": "step_2",
        "priority": 0,
        "guards": [],
        "effects": [
          {
            "kind": "set",
            "target": "context.wizard.step_1_complete",
            "expr": "true"
          }
        ]
      },
      {
        "id": "next_2",
        "event": "next",
        "from_state": "step_2",
        "to_state": "step_3",
        "priority": 0,
        "guards": [],
        "effects": [
          {
            "kind": "set",
            "target": "context.wizard.step_2_complete",
            "expr": "true"
          }
        ]
      },
      {
        "id": "submit",
        "event": "submit",
        "from_state": "step_3",
        "to_state": "submitted",
        "priority": 0,
        "guards": [],
        "effects": [
          {
            "kind": "notify",
            "template": "{{workflow_key}}.submitted"
          },
          {
            "kind": "audit",
            "template": "{{workflow_key}}.submission_recorded"
          }
        ]
      },
      {
        "id": "back_2",
        "event": "back",
        "from_state": "step_2",
        "to_state": "step_1",
        "priority": 0,
        "guards": [],
        "effects": []
      },
      {
        "id": "back_3",
        "event": "back",
        "from_state": "step_3",
        "to_state": "step_2",
        "priority": 0,
        "guards": [],
        "effects": []
      },
      {
        "id": "abandon",
        "event": "abandon",
        "from_state": "step_1",
        "to_state": "abandoned",
        "priority": 0,
        "guards": [],
        "effects": []
      }
    ]
  }
}
