{
  "project": {
    "name": "insurance-example",
    "package": "insurance_example",
    "domain": "insurance",
    "tenancy": "multi",
    "languages": ["en"],
    "currencies": ["USD"]
  },
  "shared": {
    "roles": [
      "policyholder", "claimant", "claims_adjuster", "claims_supervisor",
      "claims_manager", "siu_investigator", "subrogation_specialist",
      "outside_counsel", "underwriter", "senior_underwriter",
      "actuarial_analyst", "compliance_officer", "reinsurance_analyst",
      "litigation_manager", "finance_controller"
    ],
    "permissions": [
      "ins.claim.create", "ins.claim.assess", "ins.claim.settle",
      "ins.policy.underwrite", "ins.policy.renew", "ins.reins.place",
      "ins.subrogation.pursue", "ins.fraud.investigate",
      "ins.compliance.report", "ins.litigation.manage"
    ]
  },
  "jtbds": [
    {
      "id": "process_claim",
      "title": "Process an insurance claim end-to-end",
      "actor": {"role": "claims_adjuster"},
      "situation": "policyholder or claimant files a loss notice; adjuster must triage, investigate, evaluate, and settle or deny within statutory timeframes",
      "motivation": "resolve the claim fairly and quickly to meet regulatory timelines and preserve customer trust",
      "outcome": "claim settled or denied with documented rationale, payment issued or denial letter sent",
      "success_criteria": [
        "acknowledgement sent within 10 days of receipt",
        "coverage determination made within 15 business days",
        "payment or denial issued within 30 days of proof of loss",
        "reserve set within 48 hours of assignment"
      ],
      "data_capture": [
        {"id": "claim_number",       "kind": "text",     "label": "Claim number",          "required": true,  "pii": false},
        {"id": "policy_number",      "kind": "text",     "label": "Policy number",          "required": true,  "pii": false},
        {"id": "claimant_name",      "kind": "text",     "label": "Claimant full name",     "required": true,  "pii": true},
        {"id": "claimant_ssn_ref",   "kind": "text",     "label": "SSN reference (masked)", "required": false, "pii": true},
        {"id": "loss_date",          "kind": "date",     "label": "Date of loss",           "required": true,  "pii": false},
        {"id": "loss_description",   "kind": "textarea", "label": "Loss description",       "required": true,  "pii": false},
        {"id": "reserve_amount",     "kind": "money",    "label": "Initial reserve",        "required": true,  "pii": false},
        {"id": "settlement_amount",  "kind": "money",    "label": "Settlement amount",      "required": false, "pii": false},
        {"id": "adjuster_notes",     "kind": "textarea", "label": "Adjuster notes",         "required": false, "pii": false},
        {"id": "supporting_docs",    "kind": "file",     "label": "Supporting documents",   "required": false, "pii": false}
      ],
      "edge_cases": [
        {"id": "coverage_dispute",    "condition": "coverage_determination = disputed", "handle": "escalate"},
        {"id": "large_loss",          "condition": "reserve_amount > 250000",            "handle": "escalate"},
        {"id": "siu_referral",        "condition": "fraud_indicators_score > 70",        "handle": "branch", "branch_to": "fraud_investigation"},
        {"id": "litigation_trigger",  "condition": "claimant files suit",                "handle": "branch", "branch_to": "handle_litigation"}
      ],
      "approvals": [
        {"role": "claims_supervisor", "policy": "1_of_1"},
        {"role": "claims_manager",    "policy": "authority_tier", "tier": 2}
      ],
      "notifications": [
        {"trigger": "state_enter",  "channel": "email",  "audience": "claimant"},
        {"trigger": "approved",     "channel": "email",  "audience": "claimant"},
        {"trigger": "rejected",     "channel": "email",  "audience": "claimant"},
        {"trigger": "sla_warn",     "channel": "in_app", "audience": "claims_adjuster"},
        {"trigger": "sla_breach",   "channel": "slack",  "audience": "claims_manager"}
      ],
      "sla": {"warn_pct": 75, "breach_seconds": 2592000},
      "metrics": ["time_to_acknowledge", "time_to_settle", "reserve_accuracy_pct", "litigation_rate"],
      "compliance": ["NAIC_UCSPA", "CA_10CCR_2695", "NY_11NYCRR_216", "GDPR", "CCPA"],
      "data_sensitivity": ["pii", "financial", "medical"]
    },
    {
      "id": "underwrite_policy",
      "title": "Underwrite a new insurance policy",
      "actor": {"role": "underwriter"},
      "situation": "broker submits a new business application; underwriter must assess risk, rate, and bind or decline coverage",
      "motivation": "accept profitable risks at adequate price within authority limits while maintaining portfolio balance",
      "outcome": "policy bound with documented rationale and signed binder, or declined with written reason",
      "success_criteria": [
        "quote issued within 5 business days of complete application",
        "premium within actuarially approved rate range",
        "all subjectivities cleared before binding",
        "OFAC screening completed before binding"
      ],
      "data_capture": [
        {"id": "applicant_name",     "kind": "text",    "label": "Applicant name",       "required": true,  "pii": true},
        {"id": "applicant_ein",      "kind": "text",    "label": "Employer ID (EIN)",    "required": false, "pii": true},
        {"id": "coverage_type",      "kind": "enum",    "label": "Coverage type",        "required": true,  "pii": false},
        {"id": "requested_limit",    "kind": "money",   "label": "Requested limit",      "required": true,  "pii": false},
        {"id": "deductible",         "kind": "money",   "label": "Deductible",           "required": true,  "pii": false},
        {"id": "annual_premium",     "kind": "money",   "label": "Annual premium",       "required": true,  "pii": false},
        {"id": "risk_score",         "kind": "number",  "label": "Underwriting score",   "required": true,  "pii": false},
        {"id": "inspection_report",  "kind": "file",    "label": "Inspection report",    "required": false, "pii": false},
        {"id": "subjectivities",     "kind": "textarea","label": "Subjectivities",       "required": false, "pii": false}
      ],
      "edge_cases": [
        {"id": "above_authority",    "condition": "requested_limit > underwriter_authority", "handle": "escalate"},
        {"id": "ofac_hit",           "condition": "ofac_screening_result = match",           "handle": "reject"},
        {"id": "poor_loss_history",  "condition": "loss_ratio_5yr > 0.85",                   "handle": "escalate"}
      ],
      "approvals": [
        {"role": "senior_underwriter", "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "underwriter"},
        {"trigger": "approved",    "channel": "email",  "audience": "underwriter"},
        {"trigger": "rejected",    "channel": "email",  "audience": "underwriter"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "underwriter"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "senior_underwriter"}
      ],
      "sla": {"warn_pct": 70, "breach_seconds": 432000},
      "metrics": ["quote_to_bind_rate", "time_to_quote", "premium_adequacy_ratio", "declination_rate"],
      "compliance": ["OFAC_31CFR501", "GLBA", "GDPR", "CCPA"],
      "data_sensitivity": ["pii", "financial", "confidential_business"]
    },
    {
      "id": "handle_reinsurance",
      "title": "Place facultative reinsurance cession",
      "actor": {"role": "reinsurance_analyst"},
      "situation": "a large or unusual risk exceeds treaty capacity; analyst must obtain facultative reinsurance from markets before binding",
      "motivation": "protect balance sheet from catastrophic loss while remaining competitive on pricing",
      "outcome": "facultative certificate issued, cession recorded in bordereau, premium split booked",
      "success_criteria": [
        "fac quote obtained from at least two markets",
        "cession recorded before policy inception",
        "bordereau updated within 5 business days of month-end",
        "trust fund balance verified for NY Reg 114 compliance"
      ],
      "data_capture": [
        {"id": "cedent_policy_ref",  "kind": "text",  "label": "Cedent policy reference", "required": true,  "pii": false},
        {"id": "cession_pct",        "kind": "number","label": "Cession percentage",       "required": true,  "pii": false},
        {"id": "reins_limit",        "kind": "money", "label": "Reinsurance limit",        "required": true,  "pii": false},
        {"id": "reins_premium",      "kind": "money", "label": "Reinsurance premium",      "required": true,  "pii": false},
        {"id": "reinsurer_name",     "kind": "text",  "label": "Reinsurer name",           "required": true,  "pii": false},
        {"id": "fac_cert_number",    "kind": "text",  "label": "Fac certificate number",   "required": true,  "pii": false},
        {"id": "fac_cert_file",      "kind": "file",  "label": "Fac certificate document", "required": true,  "pii": false}
      ],
      "edge_cases": [
        {"id": "market_declination", "condition": "fewer than two markets quote",              "handle": "escalate"},
        {"id": "trust_deficit",      "condition": "reg114_trust_balance < required_minimum",  "handle": "reject"},
        {"id": "inception_overrun",  "condition": "cession_not_placed_before_inception",      "handle": "escalate"}
      ],
      "approvals": [
        {"role": "chief_reinsurance_officer", "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "reinsurance_analyst"},
        {"trigger": "approved",    "channel": "email",  "audience": "reinsurance_analyst"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "reinsurance_analyst"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "chief_reinsurance_officer"}
      ],
      "sla": {"warn_pct": 80, "breach_seconds": 259200},
      "metrics": ["cession_fill_rate", "fac_placement_cycle_time", "bordereau_timeliness_pct"],
      "compliance": ["NAIC_Model785", "NAIC_Model786", "NY_Reg114", "OFAC_31CFR501"],
      "data_sensitivity": ["financial", "confidential_business"]
    },
    {
      "id": "manage_renewal",
      "title": "Manage policy renewal underwriting",
      "actor": {"role": "underwriter"},
      "situation": "policy approaching expiry; underwriter must re-evaluate loss history, update rating factors, and issue renewal terms or non-renewal notice",
      "motivation": "retain profitable accounts and achieve adequate rate on challenging ones before competitor quoting window closes",
      "outcome": "renewal quote issued and bound, or non-renewal notice sent within statutory deadline",
      "success_criteria": [
        "renewal review initiated 90 days before expiry",
        "non-renewal notice sent at least 60 days before expiry",
        "loss adjustment factor applied per actuarial indication",
        "renewed premium variance from prior year documented"
      ],
      "data_capture": [
        {"id": "policy_number",       "kind": "text",    "label": "Expiring policy number", "required": true,  "pii": false},
        {"id": "expiry_date",         "kind": "date",    "label": "Expiry date",            "required": true,  "pii": false},
        {"id": "prior_premium",       "kind": "money",   "label": "Prior year premium",     "required": true,  "pii": false},
        {"id": "renewal_premium",     "kind": "money",   "label": "Renewal premium",        "required": true,  "pii": false},
        {"id": "loss_ratio_3yr",      "kind": "number",  "label": "3-year loss ratio",      "required": true,  "pii": false},
        {"id": "rate_change_pct",     "kind": "number",  "label": "Rate change %",          "required": true,  "pii": false},
        {"id": "renewal_decision",    "kind": "enum",    "label": "Renew / non-renew",      "required": true,  "pii": false}
      ],
      "edge_cases": [
        {"id": "non_renewal_late",    "condition": "non_renewal_notice_sent < 60_days_before_expiry", "handle": "escalate"},
        {"id": "large_rate_increase", "condition": "rate_change_pct > 25",                            "handle": "escalate"},
        {"id": "open_claims",         "condition": "open_claim_count > 0",                            "handle": "branch", "branch_to": "reserve_review"}
      ],
      "approvals": [
        {"role": "senior_underwriter", "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "underwriter"},
        {"trigger": "approved",    "channel": "email",  "audience": "underwriter"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "underwriter"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "senior_underwriter"}
      ],
      "sla": {"warn_pct": 80, "breach_seconds": 7776000},
      "metrics": ["renewal_retention_rate", "rate_change_adequacy", "non_renewal_timeliness_pct"],
      "compliance": ["NAIC_UCSPA", "state_non_renewal_statutes", "GDPR", "CCPA"],
      "data_sensitivity": ["pii", "financial"]
    },
    {
      "id": "detect_fraud",
      "title": "Investigate suspected claim fraud",
      "actor": {"role": "siu_investigator"},
      "situation": "claim flagged by scoring model or adjuster referral; SIU investigator must gather evidence, assess fraud indicators, and recommend accept / deny / refer to law enforcement",
      "motivation": "prevent fraudulent payments and deter future fraud while avoiding wrongful denials on legitimate claims",
      "outcome": "investigation report completed with finding and disposition recommendation",
      "success_criteria": [
        "SIU assignment acknowledged within 3 business days",
        "investigation report completed within 45 days",
        "law enforcement referral filed within 30 days if criminal fraud confirmed",
        "ISO ClaimSearch cross-checked before closing"
      ],
      "data_capture": [
        {"id": "siu_referral_reason", "kind": "textarea","label": "Referral reason",         "required": true,  "pii": false},
        {"id": "fraud_score",         "kind": "number",  "label": "Fraud model score",       "required": true,  "pii": false},
        {"id": "iso_claim_search_ref","kind": "text",    "label": "ISO ClaimSearch ref",      "required": false, "pii": false},
        {"id": "surveillance_report", "kind": "file",    "label": "Surveillance report",      "required": false, "pii": false},
        {"id": "recorded_statement",  "kind": "file",    "label": "Recorded statement",       "required": false, "pii": true},
        {"id": "finding",             "kind": "enum",    "label": "SIU finding",              "required": true,  "pii": false},
        {"id": "le_referral_number",  "kind": "text",    "label": "Law enforcement ref",      "required": false, "pii": false}
      ],
      "edge_cases": [
        {"id": "organized_ring",      "condition": "multiple_claimants_linked = true",     "handle": "escalate"},
        {"id": "attorney_represented","condition": "claimant_represented_by_counsel = true","handle": "branch", "branch_to": "handle_litigation"},
        {"id": "statute_expiring",    "condition": "state_fraud_report_deadline_within_7_days", "handle": "escalate"}
      ],
      "approvals": [
        {"role": "claims_manager", "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "siu_investigator"},
        {"trigger": "approved",    "channel": "email",  "audience": "claims_adjuster"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "siu_investigator"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "claims_manager"}
      ],
      "sla": {"warn_pct": 70, "breach_seconds": 3888000},
      "metrics": ["fraud_detection_rate", "siu_cycle_time", "le_referral_rate", "savings_per_investigation"],
      "compliance": ["NAIC_fraud_reporting_model", "state_fraud_bureau_statutes", "FCRA", "GDPR"],
      "data_sensitivity": ["pii", "sensitive_investigation", "medical"]
    },
    {
      "id": "process_subrogation",
      "title": "Pursue subrogation recovery",
      "actor": {"role": "subrogation_specialist"},
      "situation": "claim paid where a third party is liable; specialist must identify subrogation potential, demand reimbursement, and negotiate or litigate recovery",
      "motivation": "recover paid losses from responsible third parties to reduce net loss cost",
      "outcome": "recovery collected and claim file closed, or subrogation waived with documented rationale",
      "success_criteria": [
        "subrogation evaluation completed within 30 days of claim payment",
        "demand letter issued within 60 days of payment where potential identified",
        "arbitration or litigation filed before statute of limitations minus 90 days",
        "recovery proceeds applied to correct claim and expense accounts"
      ],
      "data_capture": [
        {"id": "third_party_name",    "kind": "text",    "label": "Third party name",        "required": true,  "pii": true},
        {"id": "third_party_insurer", "kind": "text",    "label": "Third party insurer",     "required": false, "pii": false},
        {"id": "paid_loss_amount",    "kind": "money",   "label": "Paid loss amount",        "required": true,  "pii": false},
        {"id": "recovery_demand",     "kind": "money",   "label": "Demand amount",           "required": true,  "pii": false},
        {"id": "recovery_amount",     "kind": "money",   "label": "Actual recovery",         "required": false, "pii": false},
        {"id": "demand_letter",       "kind": "file",    "label": "Demand letter",           "required": false, "pii": false},
        {"id": "arbitration_forum",   "kind": "enum",    "label": "Arbitration forum",       "required": false, "pii": false}
      ],
      "edge_cases": [
        {"id": "sol_risk",            "condition": "statute_of_limitations_within_180_days", "handle": "escalate"},
        {"id": "waiver_required",     "condition": "insured_partially_at_fault",             "handle": "branch", "branch_to": "waiver_approval"},
        {"id": "intercompany_arbitration", "condition": "third_party_is_insurer",            "handle": "branch", "branch_to": "ica_process"}
      ],
      "approvals": [
        {"role": "subrogation_supervisor", "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "subrogation_specialist"},
        {"trigger": "approved",    "channel": "email",  "audience": "subrogation_specialist"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "subrogation_specialist"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "claims_manager"}
      ],
      "sla": {"warn_pct": 75, "breach_seconds": 5184000},
      "metrics": ["subrogation_recovery_rate", "recovery_to_paid_ratio", "cycle_time_to_demand", "net_recovery_per_case"],
      "compliance": ["ISO_subrogation_guidelines", "NAIC_UCSPA", "state_sol_statutes"],
      "data_sensitivity": ["pii", "financial", "legal"]
    },
    {
      "id": "handle_litigation",
      "title": "Manage claim litigation",
      "actor": {"role": "litigation_manager"},
      "situation": "claimant or policyholder files suit; litigation manager must retain counsel, set litigation reserve, manage defense strategy, and resolve case",
      "motivation": "achieve best possible outcome at minimum cost while protecting the insurer from precedent-setting adverse judgments",
      "outcome": "case resolved by settlement, verdict, or dismissal with litigation reserve closed",
      "success_criteria": [
        "defense counsel retained within 5 business days of suit filing",
        "litigation reserve set within 10 business days",
        "status reports received at least quarterly",
        "settlement authority requested before mediation"
      ],
      "data_capture": [
        {"id": "suit_filing_date",    "kind": "date",    "label": "Suit filing date",        "required": true,  "pii": false},
        {"id": "jurisdiction",        "kind": "text",    "label": "Court and jurisdiction",  "required": true,  "pii": false},
        {"id": "plaintiff_demand",    "kind": "money",   "label": "Plaintiff demand",        "required": true,  "pii": false},
        {"id": "litigation_reserve",  "kind": "money",   "label": "Litigation reserve",      "required": true,  "pii": false},
        {"id": "counsel_name",        "kind": "text",    "label": "Defense counsel",         "required": true,  "pii": false},
        {"id": "settlement_authority","kind": "money",   "label": "Settlement authority",    "required": false, "pii": false},
        {"id": "resolution_amount",   "kind": "money",   "label": "Final resolution amount", "required": false, "pii": false},
        {"id": "resolution_type",     "kind": "enum",    "label": "Settlement / verdict / dismissal", "required": false, "pii": false}
      ],
      "edge_cases": [
        {"id": "excess_exposure",     "condition": "plaintiff_demand > policy_limit",           "handle": "escalate"},
        {"id": "bad_faith_allegation","condition": "bad_faith_claim_alleged = true",            "handle": "escalate"},
        {"id": "class_action",        "condition": "suit_type = class_action",                  "handle": "escalate"}
      ],
      "approvals": [
        {"role": "claims_manager",    "policy": "authority_tier", "tier": 2},
        {"role": "coverage_counsel",  "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "litigation_manager"},
        {"trigger": "approved",    "channel": "email",  "audience": "litigation_manager"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "litigation_manager"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "claims_manager"}
      ],
      "sla": {"warn_pct": 75, "breach_seconds": 15552000},
      "metrics": ["litigation_closure_rate", "avg_defense_cost", "settlement_vs_verdict_ratio", "excess_verdict_rate"],
      "compliance": ["ABA_model_rules", "state_bar_rules", "NAIC_UCSPA"],
      "data_sensitivity": ["pii", "legal", "financial", "privileged"]
    },
    {
      "id": "file_regulatory_report",
      "title": "File regulatory compliance report",
      "actor": {"role": "compliance_officer"},
      "situation": "state insurance department or NAIC requires periodic filing (market conduct, financial, fraud statistics, or claim data call); compliance officer must compile, review, and submit on time",
      "motivation": "maintain good standing with regulators and avoid fines or market conduct examinations",
      "outcome": "report filed with regulatory authority, confirmation received and archived",
      "success_criteria": [
        "data extracted and validated 15 days before filing deadline",
        "management certification obtained before submission",
        "confirmation receipt archived within 24 hours of filing",
        "prior-year comparison variance explained if > 10%"
      ],
      "data_capture": [
        {"id": "report_type",         "kind": "enum",    "label": "Report type",             "required": true,  "pii": false},
        {"id": "filing_jurisdiction", "kind": "text",    "label": "Filing jurisdiction",     "required": true,  "pii": false},
        {"id": "filing_deadline",     "kind": "date",    "label": "Filing deadline",         "required": true,  "pii": false},
        {"id": "report_period",       "kind": "text",    "label": "Reporting period",        "required": true,  "pii": false},
        {"id": "report_file",         "kind": "file",    "label": "Report file",             "required": true,  "pii": false},
        {"id": "mgmt_certification",  "kind": "signature","label": "Management certification","required": true, "pii": true},
        {"id": "confirmation_receipt","kind": "file",    "label": "Regulator confirmation",  "required": false, "pii": false}
      ],
      "edge_cases": [
        {"id": "data_quality_fail",   "condition": "validation_error_count > 0",               "handle": "reject"},
        {"id": "late_filing_risk",    "condition": "days_to_deadline < 3",                     "handle": "escalate"},
        {"id": "amendment_required",  "condition": "regulator_requests_amendment = true",      "handle": "branch", "branch_to": "amend_filing"}
      ],
      "approvals": [
        {"role": "compliance_officer", "policy": "1_of_1"},
        {"role": "finance_controller", "policy": "1_of_1"}
      ],
      "notifications": [
        {"trigger": "state_enter", "channel": "email",  "audience": "compliance_officer"},
        {"trigger": "approved",    "channel": "email",  "audience": "compliance_officer"},
        {"trigger": "sla_warn",    "channel": "in_app", "audience": "compliance_officer"},
        {"trigger": "sla_breach",  "channel": "slack",  "audience": "compliance_officer"}
      ],
      "sla": {"warn_pct": 85, "breach_seconds": 1296000},
      "metrics": ["on_time_filing_rate", "amendment_rate", "data_quality_error_rate"],
      "compliance": ["NAIC_statutory_filings", "state_DOI_regulations", "GDPR", "CCPA"],
      "data_sensitivity": ["financial", "regulatory", "confidential_business"]
    },
    {
      "id": "process_premium_payment",
      "title": "Process premium payment and reconcile",
      "actor": {"role": "finance_controller"},
      "situation": "broker or policyholder remits premium; finance must apply payment, reconcile against billed amount, handle short pays, and issue receipts",
      "motivation": "maintain accurate accounts receivable, avoid policy cancellations for non-payment, and close reconciling items within period",
      "outcome": "payment applied to policy, receipt issued, suspense items cleared, cancellation notice avoided or reversed",
      "success_criteria": [
        "payment applied within 2 business days of receipt",
        "short-pay notice issued within 5 business days",
        "suspense balance zero at month-end",
