		"@testing-library/react": "^16.0.1",
		"@testing-library/user-event": "^14.6.0",
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"jsdom": "^25.0.0",
		"msw": "^2.3.0",
		"react": "^18.0.0",
		"react-dom": "^18.0.0",
		"typescript": "^5.5.0",
		"vitest": "^2.0.0"
