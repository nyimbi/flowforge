{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"jsx": "react-jsx",
		"isolatedModules": true,
		"noEmit": true,
		"types": ["node", "vite/client"],
		"lib": ["ES2022", "DOM"]
	},
	"include": ["harness/**/*.ts", "harness/**/*.tsx", "lib/**/*.ts", "tests/**/*.ts", "playwright.config.ts"]
}
