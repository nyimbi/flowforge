{
  "name": "flowforge",
  "scope": "Build the flowforge framework as `framework/` subtree inside the UMS repo. No PyPI/npm publish. Quality bar: every public ABC has docstring + types + default impl + test. Every package has README + CHANGELOG. JTBD generator runs the 3 worked examples (claim, hiring, permit) end-to-end with passing tests.",
  "constraints": {
    "agent_invocation_cap": 25,
    "do_not_touch": [
      "backend/app/workflows_v2/ (until migration unit U23)",
      "frontend/src/components/workflow-designer/ (until UI migration)",
      "audit-remediation work in progress"
    ],
    "reference_paths": [
      "backend/app/workflows/engine.py",
      "backend/app/workflows/definitions/",
      "backend/app/audit/service.py",
      "backend/app/workers/outbox_worker.py",
      "backend/app/db/session.py",
      "backend/app/admin/permissions.py",
      "backend/app/platform/signing.py",
      "backend/app/notifications/transports/"
    ]
  },
  "layers": [
    {
      "id": "L0",
      "name": "Repo skeleton + monorepo layout",
      "parallel_safe": false,
      "units": ["U00"]
    },
    {
      "id": "L1",
      "name": "Port ABC contracts (lock first)",
      "parallel_safe": false,
      "units": ["U01"]
    },
    {
      "id": "L2",
      "name": "PyPI packages (parallel layer A)",
      "parallel_safe": true,
      "units": ["U02", "U03", "U04", "U05", "U06", "U07"]
    },
    {
      "id": "L3",
      "name": "PyPI packages (parallel layer B)",
      "parallel_safe": true,
      "units": ["U08", "U09", "U10", "U11", "U12", "U13"]
    },
    {
      "id": "L4",
      "name": "npm packages (parallel)",
      "parallel_safe": true,
      "units": ["U14", "U15", "U16", "U17", "U18"]
    },
    {
      "id": "L5",
      "name": "JTBD generator + CLI",
      "parallel_safe": false,
      "units": ["U19"]
    },
    {
      "id": "L6",
      "name": "JTBD worked examples (parallel)",
      "parallel_safe": true,
      "units": ["U20", "U21", "U22"]
    },
    {
      "id": "L7",
      "name": "UMS migration of 23 Python defs",
      "parallel_safe": false,
      "units": ["U23"]
    },
    {
      "id": "L8",
      "name": "End-to-end gate",
      "parallel_safe": false,
      "units": ["U24"]
    }
  ],
  "units": [
    {
      "id": "U00",
      "title": "framework/ monorepo skeleton + workspace config",
      "deliverables": [
        "framework/README.md",
        "framework/CHANGELOG.md",
