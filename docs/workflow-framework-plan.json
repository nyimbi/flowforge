        "framework/python/ subdirs for 12 packages",
        "framework/js/ subdirs for 5 packages",
        "framework/js/package.json (pnpm workspace root)",
        "framework/js/pnpm-workspace.yaml",
        "framework/.gitignore",
        "framework/scripts/check_workspace.py"
      ],
      "dependencies": [],
      "acceptance_criteria": [
        "Workspace root files exist; uv sync (dry-run) parses without error",
        "pnpm-workspace.yaml lists 5 npm packages",
