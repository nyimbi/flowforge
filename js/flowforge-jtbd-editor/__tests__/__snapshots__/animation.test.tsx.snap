// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`JobMapAnimation snapshots > renders the controls toolbar exactly once 1`] = `"<div data-testid="ff-jobmap-animation-controls" role="toolbar" aria-label="JobMap animation controls" style="display: flex; gap: 8px; align-items: center;"><button type="button" data-testid="ff-jobmap-animation-play" aria-pressed="false">Play</button><button type="button" data-testid="ff-jobmap-animation-step-back" disabled="" aria-label="Step back">‹ Back</button><button type="button" data-testid="ff-jobmap-animation-step-forward" aria-label="Step forward">Forward ›</button><button type="button" data-testid="ff-jobmap-animation-reset" disabled="" aria-label="Reset animation">Reset</button><label style="display: flex; gap: 6px; align-items: center; flex-grow: 1; flex-shrink: 1; flex-basis: 0%;"><span style="font-size: 12px; color: #475569;">Step</span><input data-testid="ff-jobmap-animation-slider" aria-label="Animation step slider" min="-1" max="3" step="1" style="flex-grow: 1; flex-shrink: 1; flex-basis: 0%;" type="range" value="-1"><span data-testid="ff-jobmap-animation-step-label" style="font-size: 12px; color: #0f172a; min-width: 80px;">—</span></label></div>"`;
